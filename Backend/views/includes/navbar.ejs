<nav class="navbar navbar-expand-md border-bottom sticky-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <i class="fa-regular fa-compass"></i>
            <span class="brand-name">Hotspot</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

            <% if(typeof search !=='undefined' ) { %>
                <form action="/listing" method="GET" class="navbar-search mx-auto">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" name="search" value="<%= search %>" placeholder="Search listings..."
                            class="search-input">
                        <button type="submit" class="search-btn">Search</button>
                    </div>
                </form>
                <% } %>

                    <div class="navbar-nav ms-auto align-items-center gap-1">
                        <a class="nav-link" href="/">Home</a>
                        <a class="nav-link" href="/listing">All Listings</a>
                        <a class="nav-link" href="/listing/new">Create Listing</a>
                        <% if(!currentUser) { %>
                            <a class="nav-link" href="/login">Login</a>
                            <a class="nav-link nav-register-btn" href="/register">Register</a>
                            <% } else { %>
                                <a href="/profile" class="nav-username">
                                    <i class="fa-regular fa-circle-user"></i>
                                    <%= currentUser.firstName %>
                                </a>
                                <% } %>
                    </div>
        </div>
    </div>
</nav>

<% if(success && success.length> 0) { %>
    <div class="alert alert-success alert-dismissible fade show mb-0" role="alert">
        <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

        <% if(error && error.length> 0) { %>
            <div class="alert alert-danger alert-dismissible fade show mb-0" role="alert">
                <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>